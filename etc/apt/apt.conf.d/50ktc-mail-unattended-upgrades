// KTC Mail — unattended security updates policy
//
// Installed to /etc/apt/apt.conf.d/50ktc-mail-unattended-upgrades.
// The Unattended-Upgrade package is recommended but not required.
//
// These settings ensure that security updates are applied automatically
// while keeping the ktc-mail package at its pinned version unless the
// admin explicitly upgrades.

Unattended-Upgrade::Allowed-Origins {
    "${distro_id}:${distro_codename}-security";
    "${distro_id}ESMApps:${distro_codename}-apps-security";
    "${distro_id}ESM:${distro_codename}-infra-security";
};

// Never automatically upgrade ktc-mail itself — the admin must
// explicitly install new versions after reviewing changelogs.
Unattended-Upgrade::Package-Blacklist {
    "ktc-mail";
};

// Auto-fix broken packages
Unattended-Upgrade::AutoFixInterruptedDpkg "true";

// Send email on failure (requires mailx to be configured)
Unattended-Upgrade::Mail "";

// Remove unused kernel packages
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";

// Remove unused dependencies
Unattended-Upgrade::Remove-New-Unused-Dependencies "true";

// Automatically reboot *only* if required by a kernel security update
Unattended-Upgrade::Automatic-Reboot "false";
Unattended-Upgrade::Automatic-Reboot-WithUsers "false";

// Reboot time if automatic reboot is enabled
// Unattended-Upgrade::Automatic-Reboot-Time "03:00";
