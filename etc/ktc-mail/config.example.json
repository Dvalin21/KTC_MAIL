{
  "domain": "example.com",
  "hostname": "mail.example.com",
  "admin_host": "admin.example.com",
  "webmail_host": "webmail.example.com",
  "admin_email": "admin@example.com",
  "public_ipv4": "203.0.113.10",
  "public_ipv6": "2001:db8::10",
  "dns_provider": "cloudflare",
  "certificate_mode": "dns-01-api",
  "manage_system_hostname": true,
  "open_ports": [22, 25, 443, 587, 993, 4190],
  "dns_records": [],
  "renewal_hooks": {
    "update_tlsa_on_certificate_renewal": true,
    "reload_services": ["postfix", "dovecot", "nginx"]
  },
  "implementation_phase": "Phase 2",
  "security": {
    "admin_mfa_required": true,
    "fail2ban_enabled": true,
    "rspamd_enabled": true,
    "dmarc_policy_target": "reject",
    "mta_sts_enabled": true,
    "tls_rpt_enabled": true,
    "audit_log_retention_days": 365
  }
}
