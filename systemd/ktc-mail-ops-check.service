[Unit]
Description=KTC Mail backup and observability check
After=network-online.target

[Service]
Type=oneshot
User=root
ExecStart=/usr/lib/ktc-mail/ops_controls.py check --config /etc/ktc-mail/setup.json
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/ktc-mail
